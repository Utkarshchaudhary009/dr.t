TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret_here

# Supabase — server-side only (never expose to the browser)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJh...your_service_role_key_here

# Optional: override the public URL used by /api/webhook/telegram/register
# Defaults to the request's own origin, then VERCEL_URL (auto-injected by Vercel)
# WEBHOOK_URL=https://your-custom-domain.com
